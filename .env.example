# Скопіюй у .env і заповни (для локального запуску).
# У GitHub Actions ці значення задаються в Settings -> Secrets and variables -> Actions.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Достатньо хоча б одного ключа; решта — резерв (фолбек).
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Необов'язкові перевизначення:
# CLAUDE_MODEL=claude-sonnet-5
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
# LOOKBACK_HOURS=13
